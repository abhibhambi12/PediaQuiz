{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2021",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "composite": true,
    "declaration": true,
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types"],
    "types": ["node"]
  },
  "compileOnSave": true,
  "include": [
    "src/**/*.ts"
  ],
  "references": [
    {
      "path": "../types"
    }
  ],
  "exclude": ["node_modules", "lib"]
}