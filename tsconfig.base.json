{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@pediaquiz/types": ["packages/types/src"]
    }
  }
}