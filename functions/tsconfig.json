{
  "compilerOptions": {
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2021",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    
    "module": "NodeNext", // UPDATED for modern Node.js module resolution
    "moduleResolution": "NodeNext", // UPDATED for modern Node.js module resolution
    "types": ["node"] // NEW: Ensures Node.js global types are recognized
  },
  "compileOnSave": true,
  "include": [
    "src"
  ],
  "references": [
    {
      "path": "../packages/types"
    }
  ]
}