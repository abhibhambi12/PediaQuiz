{
  "compilerOptions": {
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2021",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    
    // Both 'module' and 'moduleResolution' MUST be 'Node16' for consistency
    // with modern module resolution and CommonJS output.
    "module": "Node16",
    "moduleResolution": "Node16"
  },
  "compileOnSave": true,
  "include": [
    "src"
  ],
  "references": [
    {
      "path": "../packages/types"
    }
  ]
}